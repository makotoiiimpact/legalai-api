# LegalAI API — Environment Variables
# Set these in Railway dashboard: Settings → Variables

# Supabase — prod (kapyskpusteokxuaquwo). Used by old routes in main.py.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase — dev (cfiaxrvtafszmgraftbk). Used by routes/intake.py (/api/v2/*).
SUPABASE_DEV_URL=https://cfiaxrvtafszmgraftbk.supabase.co
SUPABASE_DEV_SERVICE_KEY=your-dev-service-role-key

# OpenAI (embeddings — text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Anthropic (Claude — analysis + memo generation)
ANTHROPIC_API_KEY=sk-ant-...

# Railway sets PORT automatically — do not override
# PORT=8080
