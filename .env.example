# LegalAI API — Environment Variables
# Set these in Railway dashboard: Settings → Variables

# Supabase — used by all routes (main.py + /api/v2/* in routes/intake.py).
# On Railway, point at prod (kapyskpusteokxuaquwo). Locally, at dev.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# OpenAI (embeddings — text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Anthropic (Claude — analysis + memo generation)
ANTHROPIC_API_KEY=sk-ant-...

# Railway sets PORT automatically — do not override
# PORT=8080
